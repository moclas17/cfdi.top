# AutoFactura - Configuración de entorno
# Copiar este archivo como .env y configurar los valores

# Base de datos
DB_HOST=localhost
DB_PORT=3306
DB_NAME=autofactura
DB_USER=root
DB_PASS=

# Aplicación
APP_NAME=AutoFactura
APP_URL=http://localhost/autofactura
APP_BASE_PATH=/autofactura
APP_ENV=development
APP_DEBUG=true
APP_KEY=base64:GENERATE_A_RANDOM_32_BYTE_KEY
APP_TIMEZONE=America/Mexico_City

# Sesiones
SESSION_LIFETIME=3600

# Seguridad
CSRF_TOKEN_LIFETIME=3600

# Mailgun
MAILGUN_ENABLED=false
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_BASE_URL=https://api.mailgun.net/v3
MAILGUN_FROM_EMAIL=
MAILGUN_FROM_NAME=AutoFactura
MAIL_TEMPLATE_LOGO_URL=

# Mensajes.xyz (WhatsApp)
MENSAJES_ENABLED=false
MENSAJES_BASE_URL=https://api.mensajes.xyz
MENSAJES_SEND_PATH=/v1/notify.php
MENSAJES_API_KEY=
MENSAJES_ACCOUNT_NAME=efectosfiscales
MENSAJES_INCLUDE_ACCOUNT_NAME=false
MENSAJES_TEMPLATE_NAME=autofactura_factura_link_v1
MENSAJES_TEMPLATE_LANGUAGE=es_MX
MENSAJES_TEMPLATE_FORMAT=body_named
MENSAJES_PARAM_NAME=cliente
MENSAJES_PARAM_BUSINESS=negocio
MENSAJES_PARAM_CONCEPT=concepto
MENSAJES_PARAM_AMOUNT=importe
MENSAJES_PARAM_EXPIRES=vence
MENSAJES_PARAM_LINK=link_factura
MENSAJES_DEFAULT_COUNTRY=52
MENSAJES_TIMEOUT=20

# Clip Checkout
CLIP_API_BASE=https://api.payclip.com/v2/checkout
CLIP_API_KEY=
CLIP_API_SECRET=
CLIP_API_TOKEN=
CLIP_WEBHOOK_TOKEN=
CLIP_WEBHOOK_SECRET=
CLIP_WEBHOOK_SIGNATURE_HEADER=X-Clip-Signature

# EfectosFiscales - Alta automática de cuenta de timbrado
EF_ASSIGN_URL=https://efectosfiscales.mx/assign/api_usuario_alta.php
EF_ASSIGN_BEARER=
EF_TRANSFER_URL=https://efectosfiscales.mx/assign/api_transferir_timbres.php
EF_TRANSFER_BEARER=
EF_DEFAULT_API_URL=https://efectosfiscales.mx/wscfditop/?wsdl
